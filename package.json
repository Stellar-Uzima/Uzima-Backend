    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "i18next": "^25.5.3",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-middleware": "^3.8.1",
    "ioredis": "^5.8.1",
    "ipfs-http-client": "^60.0.1",
